# Biometric Device Config
DEVICE_PORT=4370

# Frappe Configuration
FRAPPE_SITE= ""
API_KEY=""
API_SECRET=""

# Shift-Device Mapping is no longer configured here.
# Devices and employee mappings are now managed in ERPNext via:
#   Frappe > TB Hotel Core > Biometric Device Registration
# The tool loads active devices automatically from ERPNext at startup.


# Automatic Mapping Configuration
# This field in the ERPNext 'Employee' DocType should match the Biometric User ID.
# Common values: 'attendance_device_id' (standard) or 'user_id'.
FRAPPE_EMPLOYEE_FIELD=attendance_device_id
