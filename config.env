# Biometric Device Config
DEVICE_PORT=4370

# Frappe Configuration
FRAPPE_SITE=https://example.com
API_KEY=""
API_SECRET=""

# Shift-Device Mapping (JSON format)
# Maps Shift Types to specific Device Serial Numbers or Device IDs (Machine Number).
# Example: {"General Shift": ["serial no", "device id"], "Night Shift": [""]}
SHIFT_DEVICE_MAP='{"Test Shift": ["2"]}'


# Automatic Mapping Configuration
# This field in the ERPNext 'Employee' DocType should match the Biometric User ID.
# Common values: 'attendance_device_id' (standard) or 'user_id'.
FRAPPE_EMPLOYEE_FIELD=attendance_device_id
